bool error() {
	// check if input is a non # or invalid
	if (cin.fail()) {
		cin.clear();
		cin.ignore(1000, '\n');
		cout<<"Invalid input. Please try again.\n";
		return true;
	}
	return false;
}

void intro() {
	int introAns;

	// find circuit
	cout<<"What kind of circuit is being calculated for?"<<endl;
	cout<<"1) Parallel\n2) Series"<<endl;

	while(true) {
