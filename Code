	// calc directory
	if(paraAns==1) {
		calc_paraRT();
	} else if(paraAns==2) {
		calc_paraI();
	}
}

void calc_paraRT() {
	int para_numRT;
	double para_resRT, para_sumRT=0.0;

	cout<<"\n";

    // find number of resistors 
	while(true) {
		cout<<"Enter number of resistors: ";
		cin>>para_numRT;

		if(error()) continue;

		if(para_numRT<=0) {
			cout<<"Invalid input. Please try again.\n";
			continue;
		}
		break;
	}

	cout<<"\n";

    // find resistance values 
	for(int i=0; i<para_numRT; i++) {
		while(true) {
			cout<<"Enter resistance for resistor "<<i+1<<": ";
			cin>>para_resRT;

			if(error()) continue;

			if(para_resRT<=0) {
				cout<<"Resistance must be positive. Please try again.\n";
				continue;
			}
			break;
		}
        
        // inverse inputs, inverse total
		para_sumRT+=1.0/para_resRT;
	}

	cout<<"\n";

	double para_totRT=1.0/para_sumRT;
	cout<<"Total resistance in parallel: "<<para_totRT<<" ohms\n";
}

void calc_paraI() {
    int para_numRT;
    double resistors[100];
	double para_resRT, para_sumRT=0.0;

	cout<<"\n";

    // find number of resistors 
	while(true) {
		cout<<"Enter number of resistors: ";
		cin>>para_numRT;

		if(error()) continue;

		if(para_numRT<=0) {
			cout<<"Invalid input. Please try again.\n";
			continue;
		}
		break;
	}

	cout<<"\n";

    // find resistance value 
	for(int i=0; i<para_numRT; i++) {
		while(true) {
			cout<<"Enter resistance for resistor "<<i+1<<": ";
			cin>>para_resRT;

			if(error()) continue;

			if(para_resRT<=0) {
				cout<<"Resistance must be positive. Please try again.\n";
				continue;
			}
			break;
		}
    
        // turn RT into integer 
        resistors[i]=para_resRT;
        
        // inverse inputs, inverse total 
		para_sumRT+=1.0/resistors[i];
	}
	
	double para_totRT=1.0/para_sumRT;
	
	int para_volI;
	double para_curI=0.0;
	
	cout<<"\n";
	
	// find voltage 
	while(true){
	    cout<<"Enter total voltage: ";
	    cin>>para_volI;
	    
	    if(error()) continue;
	   
        if(para_volI<=0) {
            cout<<"Voltage must be positive. Please try again.\n";
            continue;
        }
        break;
	}
	
	// find current 
	para_curI=para_volI/para_totRT;
	
	cout<<"\n";
	
	// multiply RT/Rx by current and loop print 
	for(int i=0; i<para_numRT; i++){
	    double para_CURI=(para_totRT/resistors[i])*para_curI;
	    cout<<"Resistor "<<i+1<<": "<<para_CURI*100<<" mA\n";
	}
}

